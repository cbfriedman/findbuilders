# Copy to .env.local and fill in values (never commit .env.local).

# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only (webhooks / privileged server actions). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: auth redirect in local dev (e.g. http://localhost:3000/auth/callback)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# Stripe — Dashboard → Developers → API keys & Webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: canonical site URL for checkout redirects (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=
